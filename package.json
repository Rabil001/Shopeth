    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.2",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "@opennextjs/cloudflare": "^1.8.1",
    "wrangler": "^4.76.0"
  }
}
